# Shuffle web client env vars. Vite picks up VITE_-prefixed values at
# build time and inlines them into the bundle.
#
# Local dev: copy to apps/web/.env.local and the dev server picks it up.
# Vercel: set the same variable under Project Settings → Environment
# Variables, then redeploy.

# WebSocket URL of your deployed Colyseus server. The client also derives
# the HTTP base for /livekit/token and /og.svg by swapping wss → https.
# Leave empty for LAN dev — the client falls back to `${proto}://${host}:2567`.
# VITE_SERVER_URL=wss://shuffle-server.fly.dev
