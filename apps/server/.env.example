# Shuffle server env vars. Copy to apps/server/.env for local dev, or set
# them as Fly secrets in production:
#   fly secrets set LIVEKIT_URL=wss://... LIVEKIT_API_KEY=... LIVEKIT_API_SECRET=... CORS_ORIGINS=https://...

# LiveKit Cloud project — grab these from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Comma-separated list of allowed web origins. Localhost / LAN IPs are
# auto-allowed in dev. In prod, set this to your Vercel domain(s).
# CORS_ORIGINS=https://shuffle.vercel.app,https://shuffle.example.com

# Optional: override the leaderboard JSON path (defaults to ./data/leaderboard.json)
# LEADERBOARD_FILE=/data/leaderboard.json

# Optional: override the HTTP/WebSocket port (defaults to 2567)
# PORT=2567
